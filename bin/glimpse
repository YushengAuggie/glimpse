#!/usr/bin/env bash
# glimpse — a live visual canvas for AI coding agents, driven over the Chrome
# DevTools Protocol. Your agent publishes self-contained HTML artifacts to a
# local dashboard that you watch update in a real Chrome window.
#
#   glimpse open [url|#slug]      bring everything up + navigate Chrome to the canvas
#                                (first run on an empty canvas auto-shows the built-in guide; GLIMPSE_NO_WELCOME=1 opts out)
#   glimpse demo                  publish a curated set of bundled examples (guide + diagram + highlight-chat) and open the canvas
#   glimpse publish <slug> <title> [file] [--no-annotate] [--gate] [--no-audit]   publish an HTML artifact (stdin if no file)
#                                auto-audits the render and warns; --gate fails on layout errors; --no-audit skips
#   glimpse explain <slug> <title> [spec.json]   publish an interactive code-explainer (spec on stdin if omitted)
#   glimpse ask <slug> <title> [file] [--form] [--timeout N]   publish an interactive artifact,
#                                block until the user responds, print {"slug","value"} JSON.
#                                --form: `file` is a declarative form spec (JSON, stdin if
#                                omitted) rendered to native radio/checkbox/select/text controls.
#   glimpse export <slug> [--out <path>]   write a single portable HTML file (local assets inlined; remote refs kept)
#   glimpse share <slug> [--public] [--password <pw>] [--update]   upload a portable copy to ht-ml.app;
#                                PRIVATE (password) by default. --update re-uploads to the SAME page (URL kept)
#   glimpse shares [<slug>] [--json]   list shared artifacts, or show one's url + update key + password (local; no re-upload)
#   glimpse list [--json]        list artifacts (pinned first; --json for a compact machine record)
#   glimpse rm <slug>...         delete artifacts (from the feed + disk)
#   glimpse clear --all | --keep N   prune artifacts (pinned are always kept)
#   glimpse pin <slug> | unpin <slug>   pin to the top of the sidebar (persists)
#   --- highlight chat (the user selects text in an artifact and asks about it) ---
#   glimpse poll [--json] [--timeout N] [--interval S]   block until there is human feedback,
#                                print it as compact records (or JSON), then return — one call an agent parks on
#   glimpse bridge [--wait]      stream highlight-questions as JSON lines (run under an agent Monitor)
#   glimpse daemon [--wait]      always-on: bridge + auto-answer questions via the local API proxy
#   glimpse menubar              macOS menu-bar app to toggle / keep the agent online (needs uv, or rumps installed)
#   glimpse reply <slug> "answer" --to <turnId>   answer a highlighted question
#   glimpse thread <slug> [--json|--clear]   print one conversation thread
#   glimpse threads              list conversation threads
#   glimpse serve                start the static server only
#   glimpse stop                 stop the static server
#   glimpse chrome               launch a debuggable Chrome only
#   glimpse audit <slug>         report real-render layout issues (overflow/clipped/overlapping text)
#   --- review a live running app (drive Chrome to any URL, inspect + interact) ---
#   glimpse read [url]           navigate to a URL (or read the current app tab) and print {title,url,text,console,errors}
#   glimpse shot <out.png> [url] screenshot the current (or given) page
#   glimpse snapshot [#slug|url] print an accessibility-tree text snapshot (roles + names + uids); #slug → the artifact's own document
#   glimpse click <selector>     click the first element matching a CSS selector (explicit, state-changing)
#   glimpse scroll <selector> | --to <px> | --by <px>   scroll the current app page
#   glimpse wait <selector> | --text <str> [--timeout N]   wait until an element/text appears (default 8s)
#   glimpse doctor               check dependencies and running state
#   glimpse help
#
# Config via env (all optional):
#   GLIMPSE_DIR        served root           (default: ~/.glimpse)
#   GLIMPSE_PORT       canvas http port      (default: 4321)
#   GLIMPSE_CDP_PORT   chrome debug port     (default: 9222)
#   GLIMPSE_PROFILE    chrome profile dir    (default: $GLIMPSE_DIR/chrome-profile)
#   GLIMPSE_CHROME     path to chrome binary (default: auto-detect)
#   GLIMPSE_NO_WELCOME 1 to disable the first-run self-teaching guide (default: 0)
#   GLIMPSE_ANNOTATE   0 to disable highlight-chat injection globally (default: 1)
#   GLIMPSE_AUDIT      0 to disable auto-audit-on-publish (default: 1)
#   GLIMPSE_AUDIT_GATE 1 to make a bad-layout publish fail hard (default: 0; per-publish: --gate)
#   GLIMPSE_API_KEY    daemon auto-answer key (falls back to POE_API_KEY / ANTHROPIC_API_KEY)
#   GLIMPSE_PROXY_URL  daemon answer endpoint (default: $ANTHROPIC_BASE_URL/v1/messages, else http://127.0.0.1:8787/v1/messages)
#   GLIMPSE_MODEL      daemon answer model    (default: claude-haiku-4-5)
set -euo pipefail

GLIMPSE_DIR="${GLIMPSE_DIR:-$HOME/.glimpse}"
PORT="${GLIMPSE_PORT:-4321}"
CDP_PORT="${GLIMPSE_CDP_PORT:-9222}"
PROFILE="${GLIMPSE_PROFILE:-$GLIMPSE_DIR/chrome-profile}"
ARTIFACTS="$GLIMPSE_DIR/artifacts"
THREADS="$GLIMPSE_DIR/threads"
ANNOTATE="${GLIMPSE_ANNOTATE:-1}"      # 0 disables highlight-chat injection (per-publish: --no-annotate)
AUDIT="${GLIMPSE_AUDIT:-1}"            # 0 disables auto-audit-on-publish (per-publish: --no-audit)
AUDIT_GATE="${GLIMPSE_AUDIT_GATE:-0}"  # 1 makes a bad-layout publish fail hard (per-publish: --gate)
export GLIMPSE_DIR PORT CDP_PORT

# High-signal secret regex, kept in sync with scripts/check-secrets.sh (PATTERN).
# Thread turns are scrubbed against this before they are persisted, because
# ~/.glimpse/threads/ lives outside any git repo and never reaches the git guard.
SECRET_PATTERN='AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|sk-(proj-)?[A-Za-z0-9_-]{20,}|gh[pousr]_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{50,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN ([A-Z ]+ )?PRIVATE KEY-----|AIza[0-9A-Za-z_-]{35}|glpat-[A-Za-z0-9_-]{20}'
export SECRET_PATTERN
case "$PORT" in *[!0-9]*|"") echo "glimpse: GLIMPSE_PORT must be numeric" >&2; exit 1;; esac
case "$CDP_PORT" in *[!0-9]*|"") echo "glimpse: GLIMPSE_CDP_PORT must be numeric" >&2; exit 1;; esac

# Resolve this script's directory so we can find the bundled canvas/index.html
# even when run straight from the repo (before install).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"; SOURCE="$(readlink "$SOURCE")"; [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"; done
SELF_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

die(){ echo "glimpse: $*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }

# Resolve a bundled lib file (the Node/JS the dispatcher shells out to, e.g.
# glimpse-feed.mjs, glimpse-cdp.mjs). Mirrors _seed_asset's search: this checkout's
# lib/, then the copy seeded into $GLIMPSE_DIR (by install.sh / dev-link.sh), then
# a custom ~/.glimpse. Prints the resolved path; returns 1 if not found anywhere.
_lib_file(){
  local n="$1"
  if   [ -f "$SELF_DIR/../lib/$n" ]; then echo "$SELF_DIR/../lib/$n"
  elif [ -f "$GLIMPSE_DIR/$n" ];     then echo "$GLIMPSE_DIR/$n"
  elif [ -f "$HOME/.glimpse/$n" ];   then echo "$HOME/.glimpse/$n"
  else return 1; fi
}

# Resolve a bundled example artifact by filename. Mirrors _lib_file's search: this
# checkout's examples/, then the copy install.sh seeds into $GLIMPSE_DIR/examples/,
# then ~/.glimpse/examples/ (for a custom GLIMPSE_DIR). Prints the path; returns 1
# if not found anywhere, so callers can degrade gracefully.
_example_file(){
  local n="$1"
  if   [ -f "$SELF_DIR/../examples/$n" ]; then echo "$SELF_DIR/../examples/$n"
  elif [ -f "$GLIMPSE_DIR/examples/$n" ];  then echo "$GLIMPSE_DIR/examples/$n"
  elif [ -f "$HOME/.glimpse/examples/$n" ]; then echo "$HOME/.glimpse/examples/$n"
  else return 1; fi
}

# Bridge cleanup must live at script scope: an EXIT trap runs after cmd_bridge
# returns, where that function's `local`s are gone (and set -u would fire).
_BRIDGE_NODE_PID=""; _BRIDGE_LOCK=""
_bridge_cleanup(){
  # `|| true` so a failed kill (child already dead) can't abort under set -e
  # before we remove the lock.
  [ -n "${_BRIDGE_NODE_PID:-}" ] && kill "${_BRIDGE_NODE_PID}" 2>/dev/null || true
  [ -n "${_BRIDGE_LOCK:-}" ] && rm -f "${_BRIDGE_LOCK}" || true
  return 0
}

# Same at-scope cleanup for `glimpse poll` (see cmd_bridge for why this can't live
# inside the function): kill the node child and drop the poll lock on exit/signal.
_POLL_NODE_PID=""; _POLL_LOCK=""
_poll_cleanup(){
  [ -n "${_POLL_NODE_PID:-}" ] && kill "${_POLL_NODE_PID}" 2>/dev/null || true
  [ -n "${_POLL_LOCK:-}" ] && rm -f "${_POLL_LOCK}" || true
  return 0
}

# Stable, non-session node install locations to probe when `node` isn't already
# on PATH (NOT the per-shell fnm multishell dirs, which don't exist outside an
# interactive shell). Newline-delimited (paths may contain spaces). Shared by
# _ensure_node and `glimpse doctor` so the launchd-PATH check never drifts from
# the fallback it is diagnosing. Override the first entry with GLIMPSE_NODE.
_node_candidates(){
  printf '%s\n' \
    "${GLIMPSE_NODE:-}" \
    "$HOME/.local/share/fnm/aliases/default/bin/node" \
    "$HOME/.fnm/aliases/default/bin/node" \
    "/opt/homebrew/bin/node" "/usr/local/bin/node"
}

# Put node on PATH when it isn't already. Launchd starts the menu-bar app via a
# login *bash* shell, which never sources the zsh setup that fnm (or nvm) installs
# — so `node` is missing even though it's installed, and every CDP/bridge call from
# the menu bar silently dies. Prepend the first working candidate above.
_ensure_node(){
  have node && return 0
  local c
  while IFS= read -r c; do
    [ -n "$c" ] && [ -x "$c" ] && { PATH="$(dirname "$c"):$PATH"; export PATH; return 0; }
  done <<EOF
$(_node_candidates)
EOF
  return 1
}

require_node(){
  _ensure_node || true
  have node || die "node is required (glimpse runs on Node + Chrome; need v22+ for global WebSocket over CDP); set GLIMPSE_NODE=/path/to/node if it's installed somewhere unusual"
  node -e 'process.exit(parseInt(process.version.slice(1),10)>=22?0:1)' 2>/dev/null \
    || die "node $(node --version) is too old — glimpse needs node 22+ (global WebSocket). Please upgrade node."
}

detect_chrome(){
  if [ -n "${GLIMPSE_CHROME:-}" ]; then echo "$GLIMPSE_CHROME"; return; fi
  local c
  for c \
    in "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
       "/Applications/Google Chrome Canary.app/Contents/MacOS/Google Chrome Canary" \
       "/Applications/Chromium.app/Contents/MacOS/Chromium" \
       google-chrome google-chrome-stable chromium chromium-browser; do
    if [ -x "$c" ] || have "$c"; then command -v "$c" 2>/dev/null || echo "$c"; return; fi
  done
  return 1
}

seed_root(){
  mkdir -p "$ARTIFACTS"
  [ -f "$GLIMPSE_DIR/feed.json" ] || echo '{"artifacts":[]}' > "$GLIMPSE_DIR/feed.json"
  # Canvas shell + the highlight-chat helper it injects. Seed both from the repo
  # checkout, the installed copy, or ~/.glimpse (for a custom GLIMPSE_DIR).
  _seed_asset(){    # <filename> [required]
    local name="$1" required="${2:-}"
    [ -f "$GLIMPSE_DIR/$name" ] && return 0
    if   [ -f "$SELF_DIR/../canvas/$name" ]; then cp "$SELF_DIR/../canvas/$name" "$GLIMPSE_DIR/$name"
    elif [ -f "$SELF_DIR/../lib/$name" ];    then cp "$SELF_DIR/../lib/$name"    "$GLIMPSE_DIR/$name"
    elif [ -f "$HOME/.glimpse/$name" ];      then cp "$HOME/.glimpse/$name"      "$GLIMPSE_DIR/$name"
    elif [ -n "$required" ]; then die "canvas/$name not found; reinstall glimpse"; fi
  }
  _seed_asset index.html required
  _seed_asset glimpse-annotate.js
  _seed_asset glimpse-explain.mjs
  _seed_asset glimpse-explain.js
  _seed_asset glimpse-audit.js
  _seed_asset favicon.svg
}

# Upsert one artifact into feed.json under an exclusive lock (serializes the
# read-modify-write so concurrent publishes can't drop each other's entry).
# args: slug title ts pending(0|1) noannotate(0|1)
feed_upsert(){
  require_node
  local f; f="$(_lib_file glimpse-feed.mjs)" || die "glimpse-feed.mjs not found — reinstall glimpse"
  SLUG="$1" TITLE="$2" TS="$3" PENDING="${4:-0}" NOANNOTATE="${5:-0}" KIND="${6:-}" node "$f" upsert
}

# Mutate feed.json under an exclusive lock. ACTION (env) ∈ remove|removeall|keep|pin|unpin.
# For remove/removeall/keep it prints the removed slugs (one per line) so the
# caller can delete the matching artifact files.
_feed_op(){
  require_node
  local f; f="$(_lib_file glimpse-feed.mjs)" || die "glimpse-feed.mjs not found — reinstall glimpse"
  node "$f" op
}

# Per-document conversation store: threads/<slug>.json, one exclusive-locked,
# atomic read-modify-write (mirrors feed_upsert) so a flocked agent `reply` and
# the bridge's pending-question write can never corrupt each other, and the
# static server never serves a half-written file. ACTION (env) ∈
#   add_user   SLUG ANCHOR(json) QUOTE TEXT CLIENT_TURN_ID ARTIFACT_TS TS  → prints the turn id
#   add_agent  SLUG TEXT TO TS                                            → prints the turn id, flips TO→answered
#   clear      SLUG
#   print      SLUG            (readable transcript)
#   print_json SLUG            (raw file)
# Turn text/quote are capped and secret-scrubbed; files are chmod 0600.
_thread_op(){
  require_node
  local f; f="$(_lib_file glimpse-threads.mjs)" || die "glimpse-threads.mjs not found — reinstall glimpse"
  node "$f" op
}

# The shared Chrome DevTools Protocol client (cdpConnect + fail) and the
# highlight-chat bridge now live in real files under lib/ (resolved via
# _lib_file). run_cdp and cmd_bridge splice them ahead of the per-verb body /
# bridge loop with `node --input-type=module -e`, exactly as the former
# CDP_HELPER/BRIDGE_JS heredocs did — no behavior change, just relocated source.

# run_cdp <js-body>  — wraps the body in an async IIFE with the CDP helper + error trap.
run_cdp(){
  require_node
  local cdp; cdp="$(_lib_file glimpse-cdp.mjs)" || die "glimpse-cdp.mjs not found — reinstall glimpse"
  node --input-type=module -e "$(cat "$cdp")"$'\n'"(async()=>{ try{ $1 }catch(e){ fail(e) } })()"
}

cmd_serve(){
  seed_root
  if curl -fsS "http://127.0.0.1:${PORT}/feed.json" >/dev/null 2>&1; then
    echo "canvas already serving at http://127.0.0.1:${PORT}/"; return
  fi
  require_node
  # Loopback-bound, quiet static server with the SSE freshness endpoint (see
  # lib/glimpse-server.mjs).
  local server; server="$(_lib_file glimpse-server.mjs)" || die "glimpse-server.mjs not found — reinstall glimpse"
  nohup node "$server" "$PORT" "$GLIMPSE_DIR" >"$GLIMPSE_DIR/.server.log" 2>&1 &
  echo $! > "$GLIMPSE_DIR/.server.pid"
  for _ in $(seq 1 20); do
    curl -fsS "http://127.0.0.1:${PORT}/feed.json" >/dev/null 2>&1 && { echo "canvas serving at http://127.0.0.1:${PORT}/  (root: $GLIMPSE_DIR)"; return; }
    sleep 0.3
  done
  die "static server did not come up on :$PORT (see $GLIMPSE_DIR/.server.log) — is the port already in use?"
}

cmd_stop(){
  local pid; pid="$(cat "$GLIMPSE_DIR/.server.pid" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill "$pid" 2>/dev/null; then echo "stopped canvas server (pid $pid)"; else echo "no tracked canvas server running"; fi
  rm -f "$GLIMPSE_DIR/.server.pid"
}

cmd_chrome(){
  if curl -fsS "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1; then
    echo "chrome already debuggable on http://127.0.0.1:${CDP_PORT}"
    echo "  ⚠ reusing an existing CDP endpoint. If you did NOT start it with glimpse," >&2
    echo "    it may be a different Chrome (e.g. your main profile, with your logins)." >&2
    echo "    Set a different GLIMPSE_CDP_PORT to force a dedicated instance." >&2
    return
  fi
  local chrome; chrome="$(detect_chrome)" || die "could not find Chrome; set GLIMPSE_CHROME=/path/to/chrome"
  mkdir -p "$PROFILE/Default"
  # Brand the profile so the automation window is unmistakable at a glance: its
  # toolbar profile chip reads "🤖 Glimpse (automation)" instead of your Google
  # account name/photo. Chrome shows the name from Local State's info_cache (the
  # authoritative display name), so patch that as well as per-profile Preferences.
  # Patch (never overwrite) so existing settings survive; picked up on next launch
  # (see lib/glimpse-chrome-profile.mjs). Best-effort: never block a launch.
  _ensure_node || true
  local profile_mod; profile_mod="$(_lib_file glimpse-chrome-profile.mjs)" || profile_mod=""
  [ -n "$profile_mod" ] && have node && GLIMPSE_PROFILE_LABEL="${GLIMPSE_PROFILE_LABEL:-🤖 Glimpse (automation)}" \
    node "$profile_mod" "$PROFILE" 2>/dev/null || true
  echo "launching Chrome (CDP 127.0.0.1:$CDP_PORT, profile: $PROFILE)"
  # Bind the debug socket to loopback explicitly — never expose CDP on the LAN.
  "$chrome" --remote-debugging-port="$CDP_PORT" --remote-debugging-address=127.0.0.1 \
    --user-data-dir="$PROFILE" --no-first-run --no-default-browser-check about:blank >/dev/null 2>&1 &
  for _ in $(seq 1 30); do
    curl -fsS "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1 && { echo "chrome ready on :$CDP_PORT"; return; }
    sleep 0.5
  done
  die "Chrome did not expose the debug port within 15s"
}

# Point the (already-served, already-launched) canvas Chrome at a target URL:
# reuse a tab whose host matches, else open a new one — never hijack an unrelated
# tab the user opened in this profile. Shared by `open` and `demo`.
_navigate_chrome(){
  URL="$1" run_cdp '
    const url=process.env.URL; let host=""; try{host=new URL(url).host;}catch{}
    const same=(u)=>{ try{ return new URL(u).host===host; }catch{ return false; } };
    const {send,waitEvent,close}=await cdpConnect(x=>x.type==="page" && host && same(x.url));
    await send("Page.enable");
    const loaded=waitEvent("Page.loadEventFired",8000).catch(()=>{});
    await send("Page.navigate",{url}); await loaded;
    try{ await send("Page.bringToFront"); }catch(_){}   // activate the tab + raise its window so the user lands on it
    close();
  '
}

# Is the feed empty (fresh install / after a full clear)? Returns 0 when there are
# no artifacts (or no feed yet). Used only to gate the first-run welcome.
_feed_empty(){
  [ -f "$GLIMPSE_DIR/feed.json" ] || return 0
  require_node
  node -e 'try{const j=JSON.parse(require("fs").readFileSync(process.env.GLIMPSE_DIR+"/feed.json","utf8"));process.exit((j.artifacts||[]).length===0?0:1)}catch{process.exit(0)}'
}

# First-run self-teaching: the very first time the canvas comes up empty, publish
# the bundled "How to use Glimpse" guide so a newcomer sees the product explain
# itself (the guide is itself a highlight-chat demo) instead of a blank canvas.
# Quiet + idempotent:
#   • only when the feed is empty                (fresh install / after a full clear)
#   • only once, ever — a ~/.glimpse/.welcomed marker survives the user later
#     dismissing/removing the guide, so it is never re-clobbered or duplicated
#   • opt out entirely with GLIMPSE_NO_WELCOME=1
#   • degrade silently (open the empty canvas as before) if the guide isn't installed
# Returns 0 iff it published the guide, so the caller can navigate to it.
_maybe_welcome(){
  [ "${GLIMPSE_NO_WELCOME:-0}" = "1" ] && return 1
  [ -f "$GLIMPSE_DIR/.welcomed" ] && return 1
  _feed_empty || return 1
  local guide; guide="$(_example_file glimpse-guide.html)" || return 1
  _write_artifact glimpse-guide "$guide"
  feed_upsert glimpse-guide "How to use Glimpse" "$(date +%s)" 0 0
  : > "$GLIMPSE_DIR/.welcomed" 2>/dev/null || true   # welcomed once — never again
  return 0
}

cmd_open(){
  # Use 127.0.0.1 to match the loopback bind (avoids localhost→::1 resolution misses).
  local target="${1:-}"
  cmd_serve >/dev/null
  cmd_chrome >/dev/null
  # No explicit target + an empty, never-welcomed canvas → auto-show the guide.
  # An explicit `glimpse open <url>`/`#slug` is untouched (target already set).
  if [ -z "$target" ] && _maybe_welcome; then target="#glimpse-guide"; fi
  target="${target:-http://127.0.0.1:${PORT}/}"
  [[ "$target" == \#* ]] && target="http://127.0.0.1:${PORT}/${target}"
  _navigate_chrome "$target"
  echo "canvas open in Chrome → $target"
}

# Publish the curated demo set (guide + diagram/plan + highlight-chat) into the
# feed. Pure disk work — no browser — so it is unit-testable on its own. Idempotent
# by slug (re-running overwrites the same slugs, never duplicates) and degrades
# per-item if an example isn't installed. Prints one line per published slug; sets
# the .welcomed marker (a demo means the user has now seen the guide). Returns 1 if
# nothing at all could be published.
_publish_demo_set(){
  seed_root
  # slug|title|example-filename
  local -a items=(
    "glimpse-guide|How to use Glimpse|glimpse-guide.html"
    "architecture-overview|Architecture Overview|architecture-overview.html"
    "highlight-chat-demo|Highlight-to-chat demo|highlight-chat-demo.html"
  )
  local e slug title file src any=0
  for e in "${items[@]}"; do
    IFS='|' read -r slug title file <<<"$e"
    if src="$(_example_file "$file")"; then
      _write_artifact "$slug" "$src"
      feed_upsert "$slug" "$title" "$(date +%s)" 0 0
      echo "published → http://127.0.0.1:${PORT}/#${slug}"
      any=1
    else
      echo "glimpse: skipped $slug — example $file not installed (reinstall glimpse)" >&2
    fi
  done
  [ "$any" = 1 ] || return 1
  : > "$GLIMPSE_DIR/.welcomed" 2>/dev/null || true
  return 0
}

# glimpse demo — publish a small curated set of bundled examples so a newcomer sees
# the range at once: the self-teaching guide + a diagram/plan artifact + the
# highlight-chat demo. Idempotent by slug, brings the canvas up, and opens the
# guide. Reuses the shipped examples/ files.
cmd_demo(){
  _publish_demo_set || die "no example artifacts found to publish — reinstall glimpse"
  cmd_serve >/dev/null
  cmd_chrome >/dev/null
  _navigate_chrome "http://127.0.0.1:${PORT}/#glimpse-guide"
  echo "demo ready → canvas open in Chrome (start with the guide in the sidebar)"
}

# Is the canvas already live (static server AND a debuggable Chrome both up)? The
# auditor only produces findings from a REAL render, so this gates whether an
# auto-audit can run without launching anything. Quick loopback curls, no side
# effects. Returns 0 when live.
_canvas_live(){
  curl -fsS "http://127.0.0.1:${PORT}/feed.json"      >/dev/null 2>&1 \
    && curl -fsS "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1
}

# Drive the injected auditor against one slug and print the raw audit JSON object
# (the same shape as window.__glimpse_audit: {slug,viewportWidth,errors,warnings,
# findings,ts}) on stdout, or an empty line if the auditor never reported. Brings
# the canvas up (idempotent) and reflects the CURRENT render. Shared by the
# standalone `audit` verb and auto-audit-on-publish so there is one capture path.
_audit_capture(){
  local slug="$1"
  cmd_serve >/dev/null
  cmd_chrome >/dev/null
  SLUG="$slug" URL="http://127.0.0.1:${PORT}/#${slug}" run_cdp '
    const slug=process.env.SLUG, url=process.env.URL, host=new URL(url).host;
    const same=(u)=>{ try{ return new URL(u).host===host; }catch{ return false; } };
    const {send,close}=await cdpConnect(x=>x.type==="page" && same(x.url));
    await send("Page.enable");
    // Navigate to the slug, then reload: guarantees the tab runs the current shell
    // (with the auditor) and renders the slug fresh, so the audit reflects this render.
    await send("Page.navigate",{url});
    await send("Page.reload",{ignoreCache:true});
    // The auditor re-runs as fonts load + layout settles, so the first pass can be
    // premature. Take the latest audit for this slug and accept it once it has stopped
    // changing for ~2 polls (past an initial settle window).
    let audit=null, stable=0, waited=0;
    for(let i=0;i<40;i++){                          // up to ~8s
      await new Promise(r=>setTimeout(r,200)); waited+=200;
      let v; try{ v=(await send("Runtime.evaluate",{expression:"JSON.stringify((window.__glimpse_audit||{})["+JSON.stringify(slug)+"]||null)",returnByValue:true})).result.value; }catch{ continue; }
      if(!v) continue;
      let o; try{ o=JSON.parse(v); }catch{ continue; }
      if(o && o.slug===slug){
        stable = (audit && audit.ts===o.ts) ? stable+1 : 0;
        audit=o;
        if(stable>=2 && waited>=1000) break;        // settled
      }
    }
    close();
    console.log(audit ? JSON.stringify(audit) : "");
  '
}

# Render-correctness check: show the artifact, let the injected auditor measure the
# REAL layout (overflow / clipped / overlapping text), and print what's wrong so an
# agent can fix it before a human reviews. Exit 2 if any error-severity finding.
cmd_audit(){
  local slug="${1:?usage: glimpse audit <slug>}"
  _validate_slug "$slug"
  local report; report="$(_lib_file glimpse-audit-report.mjs)" || die "glimpse-audit-report.mjs not found — reinstall glimpse"
  local json; json="$(_audit_capture "$slug")"
  if [ -z "$json" ]; then
    echo "glimpse: no layout audit for $slug — is it published, and is annotate enabled? (the auditor ships with highlight-chat injection)"
    exit 0
  fi
  local rc=0
  MODE=full SLUG="$slug" node "$report" <<<"$json" || rc=$?
  exit "$rc"
}

# Auto-audit a freshly-published artifact and surface a concise, actionable
# warning (on stderr, so stdout stays the published URL). Warn-only by default;
# with the gate (--gate / GLIMPSE_AUDIT_GATE=1) an error-severity finding makes
# publish exit non-zero so an agent or CI can enforce layout quality. A clean
# artifact prints nothing. Returns the report's exit code only when gating.
_publish_autoaudit(){
  local slug="$1" gate="$2" audit="${3:-1}"
  [ "$audit" = "0" ] && return 0                 # auto-audit disabled
  # Without the gate, only audit when you're already watching (canvas live) — a
  # scripted/headless publish stays a fast file write and never launches Chrome.
  # The gate is an explicit request to enforce, so it brings the canvas up.
  if [ "$gate" != "1" ] && ! _canvas_live; then return 0; fi
  local report; report="$(_lib_file glimpse-audit-report.mjs)" || return 0
  local json; json="$(_audit_capture "$slug" 2>/dev/null)" || json=""
  if [ -z "$json" ]; then
    # The auditor never reported: annotate disabled, or the render couldn't be
    # reached. Not a layout finding, so it never fails the gate — but say so under
    # --gate rather than pass silently, so CI logs aren't misleading.
    [ "$gate" = "1" ] && echo "glimpse: ⚠ layout gate — no audit for $slug (annotate off or render unreachable); not enforced" >&2
    return 0
  fi
  local out rc=0
  out="$(MODE=brief SLUG="$slug" node "$report" <<<"$json")" || rc=$?
  [ -n "$out" ] && printf '%s\n' "$out" >&2
  if [ "$gate" = "1" ] && [ "$rc" -ne 0 ]; then
    echo "glimpse: ✗ layout gate — publish flagged (rendered artifact left in place); fix the issues above, then re-publish" >&2
    return "$rc"
  fi
  return 0
}

cmd_publish(){
  local noann=0 gate="$AUDIT_GATE" audit="$AUDIT"; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-annotate) noann=1; shift;;
      --gate)        gate=1; shift;;           # turn layout findings into a hard failure
      --no-audit)    audit=0; shift;;          # skip the auto-audit entirely
      *) pos+=("$1"); shift;;
    esac
  done
  local slug="${pos[0]:-}" title="${pos[1]:-}" src="${pos[2]:-/dev/stdin}"
  [ -n "$slug" ] && [ -n "$title" ] || die "usage: glimpse publish <slug> <title> [file.html] [--no-annotate] [--gate] [--no-audit]"
  [ "$ANNOTATE" = "0" ] && noann=1            # global GLIMPSE_ANNOTATE=0 disables injection
  _validate_slug "$slug"
  seed_root
  _write_artifact "$slug" "$src"
  feed_upsert "$slug" "$title" "$(date +%s)" 0 "$noann"
  echo "published → http://127.0.0.1:${PORT}/#${slug}  (file: $ARTIFACTS/${slug}.html)"
  # Auto-audit the real render and warn (or, with the gate, fail). Its rc is the
  # verb's rc so a tripped gate propagates a non-zero exit for CI/agents.
  _publish_autoaudit "$slug" "$gate" "$audit"
}

_validate_slug(){
  # Slugs become filenames and go into the page — keep them strict (no traversal,
  # and bounded so the temp filename can't blow past the 255-byte limit).
  local s="$1"
  case "$s" in
    *[!a-zA-Z0-9._-]*) die "invalid slug '$s' (allowed: letters, digits, dot, underscore, dash)";;
    ""|.|..|*..*)      die "invalid slug '$s'";;
  esac
  [ "${#s}" -le 200 ] || die "slug too long (max 200 chars)"
}

_write_artifact(){
  # Write with predictable perms. `cp /dev/stdin` can yield a read-only file
  # (pipe mode) that can't be overwritten next time. temp + `mv -f` gives 0644.
  local slug="$1" src="$2"
  local dest="$ARTIFACTS/${slug}.html" tmp="$ARTIFACTS/.${slug}.html.tmp"
  cat -- "$src" > "$tmp"
  chmod 0644 "$tmp"
  mv -f "$tmp" "$dest"
}

# --- portable output: standalone export + private-by-default remote share ------
# `glimpse publish`/`explain`/`ask` above write to the LOCAL canvas. `export` and
# `share` here take a published artifact and emit a portable, self-contained copy:
# export writes it to disk (fully offline), share uploads it to ht-ml.app. Naming:
# the remote command is `share` (not `publish`) precisely so it can't be confused
# with — or clobber — the existing local `publish`/canvas verb.

# Print the self-contained (all LOCAL assets inlined) HTML for a published artifact
# to stdout. Inliner warnings go to stderr; the module confines reads to the
# artifact's directory and secret-scrubs the bundle (see lib/glimpse-export.mjs).
_inline_artifact(){
  local slug="$1"; local src="$ARTIFACTS/${slug}.html"
  [ -f "$src" ] || die "no artifact '$slug' — publish it first (glimpse publish $slug …). try: glimpse list"
  local mod; mod="$(_lib_file glimpse-export.mjs)" || die "export engine not found (lib/glimpse-export.mjs) — reinstall glimpse"
  require_node
  node "$mod" "$src"
}

cmd_export(){
  local out=""; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --out) out="${2:-}"; shift 2 || die "usage: glimpse export <slug> [--out <path>]";;
      *) pos+=("$1"); shift;;
    esac
  done
  local slug="${pos[0]:-}"
  [ -n "$slug" ] || die "usage: glimpse export <slug> [--out <path>]"
  _validate_slug "$slug"
  [ -f "$ARTIFACTS/${slug}.html" ] || die "no artifact '$slug' — publish it first. try: glimpse list"
  # Default to the current directory: the artifact source lives in a hidden managed
  # data dir ($GLIMPSE_DIR/artifacts), so writing "next to the source" would bury
  # the file where the user can't find it. --out overrides.
  #
  # Guard the non-interactive case: when invoked from the daemon/bridge the cwd is
  # inherited (typically "/"), so a bare $PWD default would resolve to "//<slug>…"
  # and try to write to the read-only filesystem root. If no --out was given and
  # $PWD is "/" (or not a writable directory), fall back to a managed, always-
  # writable dir ($GLIMPSE_DIR/exports) instead of failing on the root.
  local dest="$out"
  if [ -z "$dest" ]; then
    if [ "$PWD" = "/" ] || [ ! -d "$PWD" ] || [ ! -w "$PWD" ]; then
      mkdir -p "$GLIMPSE_DIR/exports" 2>/dev/null
      dest="$GLIMPSE_DIR/exports/${slug}.export.html"
    else
      dest="$PWD/${slug}.export.html"
    fi
  fi
  local ddir; ddir="$(dirname "$dest")"
  [ -d "$ddir" ] || die "output directory does not exist: $ddir"
  local tmp="$dest.glimpse-tmp.$$"
  _inline_artifact "$slug" > "$tmp" || { rm -f "$tmp"; exit 1; }
  chmod 0644 "$tmp"
  mv -f "$tmp" "$dest"
  echo "exported → $dest  (open it in any browser; no glimpse server needed)"
}

# Resolve the shares-store module (records every successful share to shares.json).
_shares_module(){ _lib_file glimpse-shares.mjs; }

# Print the stored share record for a slug as one-line JSON (empty if none). Never
# fails the caller — a missing record is a normal "not shared yet" state.
_share_record(){
  local slug="$1" mod
  mod="$(_shares_module)" || return 1
  GLIMPSE_DIR="$GLIMPSE_DIR" SLUG="$slug" SHARES_JSON=1 node "$mod" get 2>/dev/null || true
}

# Extract one field from a share-result / record JSON blob on stdin.
_json_field(){ node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const o=JSON.parse(s);process.stdout.write(String((o&&o["'"$1"'"])??""))}catch(e){}})'; }

cmd_share(){
  local public=0 password="" pw_set=0 update=0; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --public)   public=1; shift;;
      --password) password="${2:-}"; pw_set=1; shift 2 || die "usage: glimpse share <slug> [--public] [--password <pw>] [--update]";;
      --update)   update=1; shift;;
      *) pos+=("$1"); shift;;
    esac
  done
  local slug="${pos[0]:-}"
  [ -n "$slug" ] || die "usage: glimpse share <slug> [--public] [--password <pw>] [--update]"
  _validate_slug "$slug"
  [ -f "$ARTIFACTS/${slug}.html" ] || die "no artifact '$slug' — publish it first. try: glimpse list"
  require_node
  local share; share="$(_lib_file glimpse-share.mjs)" || die "share engine not found (lib/glimpse-share.mjs) — reinstall glimpse"
  [ "$public" = 1 ] && [ "$pw_set" = 1 ] && die "--public and --password are mutually exclusive"

  # --update re-uploads to the SAME ht-ml.app page (URL preserved) using the stored
  # update_key — the "manage the page later" flow. Load the prior record first.
  local up_site="" up_key="" up_url="" prev_vis="" prev_pw="" reuse=0
  if [ "$update" = 1 ]; then
    local rec; rec="$(_share_record "$slug")"
    [ -n "$rec" ] && [ "$rec" != "null" ] || die "no prior share for '$slug' — run 'glimpse share $slug' first (see 'glimpse shares')"
    up_site="$(printf '%s' "$rec" | _json_field site_id)"
    up_key="$(printf '%s'  "$rec" | _json_field update_key)"
    up_url="$(printf '%s'  "$rec" | _json_field url)"
    prev_vis="$(printf '%s' "$rec" | _json_field visibility)"
    prev_pw="$(printf '%s'  "$rec" | _json_field password)"
    [ -n "$up_site" ] && [ -n "$up_key" ] || die "the stored share record for '$slug' is missing its update key — share without --update"
    # No explicit visibility flag on an update ⇒ keep the page as it was.
    [ "$public" = 0 ] && [ "$pw_set" = 0 ] && reuse=1
  fi

  # PRIVATE by default — a firm product decision that deliberately diverges from
  # lavish's public-by-default: with no flag, publish a password-protected page.
  # Use --password if given, else mint a strong random one and print it. --public
  # opts into a fully open page. On --update with no flag, reuse the prior state.
  local gen=0
  if [ "$reuse" = 1 ]; then
    if [ "$prev_vis" = "public" ]; then public=1; password=""; else public=0; password="$prev_pw"; fi
  elif [ "$public" = 1 ]; then
    password=""
  elif [ "$pw_set" = 1 ]; then
    [ -n "$password" ] || die "--password needs a non-empty value (or use --public for an open page)"
  else
    password="$(node -e 'process.stdout.write(require("crypto").randomBytes(18).toString("base64url"))')"
    gen=1
  fi

  # One-time privacy notice (glimpse is otherwise local & serverless): make it
  # unmistakable that the artifact leaves the machine for a third-party host,
  # before the upload happens. Concise — not a nag.
  {
    local verb; verb="$([ "$update" = 1 ] && echo updating || echo uploading)"
    echo "glimpse share: $verb '$slug' to ht-ml.app — a third-party public host. The"
    echo "               artifact leaves your machine; local assets are inlined, remote refs"
    if [ "$public" = 1 ]; then
      echo "               load over the network. The page will be PUBLIC — anyone with the link can view."
    else
      echo "               load over the network. The page is PRIVATE (password-protected)."
    fi
  } >&2

  # Build the self-contained bundle offline, then hand it to the uploader on stdin.
  # On --update, pass the stored site id + key so it PUTs to the same page.
  local result
  result="$(_inline_artifact "$slug" \
    | GLIMPSE_PASSWORD="$password" \
      GLIMPSE_UPDATE_SITE_ID="$up_site" GLIMPSE_UPDATE_KEY="$up_key" GLIMPSE_UPDATE_URL="$up_url" \
      node "$share")" \
    || die "share failed (see the error above)"

  local url site_id key
  url="$(printf '%s' "$result" | _json_field url)"
  site_id="$(printf '%s' "$result" | _json_field site_id)"
  key="$(printf '%s' "$result" | _json_field update_key)"

  # Persist the record so the link (url + secret update_key + password) is
  # retrievable later via `glimpse shares` and the canvas — for both CLI and UI
  # paths. The password lives only locally (it is already on this machine).
  local mod vis; mod="$(_shares_module)" || mod=""
  vis="$([ "$public" = 1 ] && echo public || echo private)"
  if [ -n "$mod" ] && [ -n "$url" ]; then
    GLIMPSE_DIR="$GLIMPSE_DIR" SLUG="$slug" URL="$url" SITE_ID="$site_id" \
      UPDATE_KEY="$key" VISIBILITY="$vis" PASSWORD="$password" TS="$(date +%s)" \
      node "$mod" record 2>/dev/null || true
  fi

  echo "shared → $url"
  if [ "$public" = 1 ]; then
    echo "  visibility: PUBLIC — anyone with the link can view"
  else
    echo "  visibility: PRIVATE — viewers must enter this password:"
    echo "  password:   $password$([ "$gen" = 1 ] && echo '   (generated — save it; the page cannot be viewed without it)')"
  fi
  [ -n "$key" ] && echo "  update key: $key   (secret — keep it to update or manage the page later)"
  echo "  retrieve later: glimpse shares $slug   ·   update in place: glimpse share $slug --update"
  # ht-ml.app applies a changed password at its edge asynchronously: a new password
  # can take up to ~a minute to become active, and the PREVIOUS password may keep
  # working briefly until its cached auth grant expires. Flag this only when an
  # update actually changed the password, so "it didn't take" reads as expected lag,
  # not a failure. (Content updates apply immediately; only the auth layer lags.)
  if [ "$update" = 1 ] && [ "$public" = 0 ] && [ "$reuse" = 0 ]; then
    echo "  note: the new password can take up to ~a minute to activate on ht-ml.app;" >&2
    echo "        the previous password may keep working briefly while its cache expires." >&2
  fi
}

# List shared artifacts, or show one slug's full record (url + update key +
# password). Reads the local shares.json — never re-uploads. --json for machines.
cmd_shares(){
  local as_json=0; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) as_json=1; shift;;
      *) pos+=("$1"); shift;;
    esac
  done
  require_node
  local mod; mod="$(_shares_module)" || die "shares engine not found (lib/glimpse-shares.mjs) — reinstall glimpse"
  local slug="${pos[0]:-}"
  if [ -z "$slug" ]; then
    GLIMPSE_DIR="$GLIMPSE_DIR" SHARES_JSON="$([ "$as_json" = 1 ] && echo 1)" node "$mod" list
    return
  fi
  _validate_slug "$slug"
  local rec; rec="$(GLIMPSE_DIR="$GLIMPSE_DIR" SLUG="$slug" SHARES_JSON=1 node "$mod" get)" \
    || die "'$slug' has not been shared — run: glimpse share $slug"
  if [ "$as_json" = 1 ]; then printf '%s\n' "$rec"; return; fi
  local url vis key pw
  url="$(printf '%s' "$rec" | _json_field url)"
  vis="$(printf '%s' "$rec" | _json_field visibility)"
  key="$(printf '%s' "$rec" | _json_field update_key)"
  pw="$(printf '%s'  "$rec" | _json_field password)"
  echo "shared → $url"
  echo "  visibility: $([ "$vis" = public ] && echo 'PUBLIC — anyone with the link can view' || echo 'PRIVATE — needs the password below')"
  [ "$vis" != public ] && [ -n "$pw" ] && echo "  password:   $pw"
  [ -n "$key" ] && echo "  update key: $key   (secret — keep it to update the page later)"
  echo "  update in place: glimpse share $slug --update"
}

# Resolve the explain engine (validator + wrapper). Mirrors _seed_asset's search:
# repo checkout, then the seeded copy in GLIMPSE_DIR.
_explain_module(){ _lib_file glimpse-explain.mjs; }

cmd_explain(){
  local -a pos=("$@")
  local slug="${pos[0]:-}" title="${pos[1]:-}" src="${pos[2]:-/dev/stdin}"
  [ -n "$slug" ] && [ -n "$title" ] || die "usage: glimpse explain <slug> <title> [spec.json]  (spec on stdin if omitted)"
  _validate_slug "$slug"
  [ "$src" = /dev/stdin ] || [ -f "$src" ] || die "spec file not found: $src"
  local mod; mod="$(_explain_module)" || die "explain engine not found; searched \$SELF_DIR/../lib/, \$GLIMPSE_DIR/, \$HOME/.glimpse/ — reinstall glimpse"
  require_node
  seed_root
  # validate + wrap in one read of the spec; abort (and publish nothing) on error.
  # Exit codes: the module returns 2 for spec-content errors (we propagate it);
  # 1 is reserved for the verb's own usage/infra failures (die).
  local html; html="$(node "$mod" wrap "$title" < "$src")" || exit $?
  printf '%s' "$html" | _write_artifact "$slug" /dev/stdin
  feed_upsert "$slug" "$title" "$(date +%s)" 0 0 explain     # pending=0 noannotate=0 kind=explain
  echo "published → http://127.0.0.1:${PORT}/#${slug}  (file: $ARTIFACTS/${slug}.html)"
}

cmd_ask(){
  local timeout=300 form=0; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --timeout) timeout="${2:-}"; shift 2 || die "usage: glimpse ask <slug> <title> [file] [--form] [--timeout N]";;
      --form) form=1; shift;;   # source is a declarative form spec (JSON), not raw HTML
      *) pos+=("$1"); shift;;
    esac
  done
  local slug="${pos[0]:-}" title="${pos[1]:-}" src="${pos[2]:-/dev/stdin}"
  [ -n "$slug" ] && [ -n "$title" ] || die "usage: glimpse ask <slug> <title> [file] [--form] [--timeout N]"
  case "$timeout" in *[!0-9]*|"") die "--timeout must be a number of seconds";; esac
  _validate_slug "$slug"
  seed_root
  if [ "$form" = 1 ]; then
    # Declarative path: validate + render native accessible controls (radio /
    # checkbox / select / text / textarea) into an artifact that returns the
    # structured choice through the SAME glimpseRespond channel below.
    [ "$src" = /dev/stdin ] || [ -f "$src" ] || die "form spec file not found: $src"
    local mod; mod="$(_lib_file glimpse-ask.mjs)" || die "ask form engine not found; searched \$SELF_DIR/../lib/, \$GLIMPSE_DIR/, \$HOME/.glimpse/ — reinstall glimpse"
    require_node
    # validate + wrap in one read of the spec; publish nothing on error (module
    # returns 2 for spec-content errors, which we propagate; 1 is our own).
    local html; html="$(node "$mod" wrap "$title" < "$src")" || exit $?
    printf '%s' "$html" | _write_artifact "$slug" /dev/stdin
  else
    _write_artifact "$slug" "$src"
  fi
  feed_upsert "$slug" "$title" "$(date +%s)" 1 1   # pending=1 → "awaiting you"; noannotate=1 (ask owns glimpseRespond)
  cmd_serve >/dev/null
  cmd_chrome >/dev/null
  echo "glimpse: waiting for your response in the canvas (timeout ${timeout}s)…" >&2
  local rc=0
  # Navigate AND poll the SAME canvas tab in one CDP session — picking different
  # tabs for navigate vs read is the bug that made earlier asks time out.
  SLUG="$slug" TIMEOUT_MS="$((timeout*1000))" run_cdp '
    const slug=process.env.SLUG, port=process.env.PORT;
    const url="http://127.0.0.1:"+port+"/#"+slug;
    const isCanvas=(u)=>{ try{ const h=new URL(u).host; return h==="127.0.0.1:"+port||h==="localhost:"+port; }catch{ return false; } };
    // prefer a 127.0.0.1 canvas tab, then any canvas tab; cdpConnect creates one if none.
    let {send,waitEvent,close}=await cdpConnect(x=>x.type==="page" && isCanvas(x.url));
    const loaded=waitEvent("Page.loadEventFired",12000).catch(()=>{});
    await send("Page.enable"); await send("Runtime.enable");
    await send("Page.navigate",{url}); await loaded;
    try{ await send("Page.bringToFront"); }catch(_){}
    const since=Date.now(), deadline=since+Number(process.env.TIMEOUT_MS); let out=null;
    while(Date.now()<deadline){
      const r=await send("Runtime.evaluate",{expression:"JSON.stringify((window.__glimpse_responses||{})["+JSON.stringify(slug)+"]||null)",returnByValue:true});
      const v=(r&&r.result&&r.result.value)?JSON.parse(r.result.value):null;
      if(v&&v.ts>=since){ out=v; break; }
      await new Promise(z=>setTimeout(z,500));
    }
    close();
    if(out){ console.log(JSON.stringify({slug, value: out.value})); }
    else { console.error("glimpse: ask timed out after "+(Number(process.env.TIMEOUT_MS)/1000)+"s"); process.exit(2); }
  ' || rc=$?
  feed_upsert "$slug" "$title" "$(date +%s)" 0 1    # clear pending; keep noannotate=1
  return $rc
}

# Navigate to a live URL (or read whatever app tab is already open) and print
# {title,url,text,console,errors} as JSON — the text/console view of a running app.
# Read-only. With a URL, targets that app's own tab (cdpConnectApp) so it reuses the
# app tab instead of clobbering the canvas; with no URL, reads the current app tab.
# Console output + uncaught errors captured during load are the review payoff.
cmd_read(){
  local url="${1:-}"
  cmd_chrome >/dev/null
  local f; f="$(_lib_file glimpse-read.mjs)" || die "glimpse-read.mjs not found — reinstall glimpse"
  URL="$url" run_cdp "$(cat "$f")"
}

cmd_shot(){
  local out="${1:?usage: glimpse shot <out.png> [url]}" url="${2:-}"
  cmd_chrome >/dev/null
  # Navigate + bringToFront + capture over ONE cdpConnectApp(url) session, so the
  # screenshot is ALWAYS the tab we selected — re-selecting a tab for the capture
  # independently of the navigate is BUG-1 (grabs a stale/other tab, e.g. a
  # background about:blank or a de-preferred canvas). Mirrors cmd_ask, which drives
  # navigate+poll in one session for the same reason. With a URL, act on the tab
  # whose host matches it (the app's own tab, or the canvas for a canvas URL); with
  # none, capture the current app tab (non-canvas page preferred). Page.bringToFront
  # before capture guards against a backgrounded tab yielding a blank frame.
  OUT="$out" URL="$url" run_cdp '
    const url=process.env.URL||"";
    const {send,waitEvent,close}=await cdpConnectApp(url);
    await send("Page.enable");
    if(url){
      const loaded=waitEvent("Page.loadEventFired",12000).catch(()=>{});
      await send("Page.navigate",{url}); await loaded; await new Promise(r=>setTimeout(r,400));
    }
    try{ await send("Page.bringToFront"); }catch(_){}
    const {data}=await send("Page.captureScreenshot",{format:"png"});
    const fs=await import("fs"); fs.writeFileSync(process.env.OUT, Buffer.from(data,"base64"));
    console.log("saved", process.env.OUT); close();
  '
}

# --- live-app interaction: the only state-changing browser verbs ---------------
# click / scroll / wait drive the CURRENT app tab (open it first with
# `glimpse open <url>`). Each shells the shared interaction body through run_cdp
# (lib/glimpse-interact.mjs) over the one CDP channel — no second browser connection.
cmd_click(){
  local selector="${1:-}"
  [ -n "$selector" ] || die "usage: glimpse click <css-selector>"
  cmd_chrome >/dev/null
  local f; f="$(_lib_file glimpse-interact.mjs)" || die "glimpse-interact.mjs not found — reinstall glimpse"
  ACTION=click SELECTOR="$selector" run_cdp "$(cat "$f")"
}

cmd_scroll(){
  local to="" by="" set=0; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --to) to="${2:-}"; set=$((set+1)); shift 2 || die "usage: glimpse scroll <selector> | --to <px> | --by <px>";;
      --by) by="${2:-}"; set=$((set+1)); shift 2 || die "usage: glimpse scroll <selector> | --to <px> | --by <px>";;
      *) pos+=("$1"); shift;;
    esac
  done
  local selector="${pos[0]:-}"
  [ -n "$selector" ] && set=$((set+1))
  [ "$set" -eq 1 ] || die "usage: glimpse scroll <selector> | --to <px> | --by <px>   (exactly one)"
  [ -n "$to" ] && { case "$to" in *[!0-9-]*|"") die "--to must be an integer pixel offset";; esac; }
  [ -n "$by" ] && { case "$by" in *[!0-9-]*|"") die "--by must be an integer pixel delta";; esac; }
  cmd_chrome >/dev/null
  local f; f="$(_lib_file glimpse-interact.mjs)" || die "glimpse-interact.mjs not found — reinstall glimpse"
  ACTION=scroll SELECTOR="$selector" SCROLL_TO="$to" SCROLL_BY="$by" run_cdp "$(cat "$f")"
}

cmd_wait(){
  local text="" timeout=8; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --text)    text="${2:-}";    shift 2 || die 'usage: glimpse wait <selector> | --text <str> [--timeout N]';;
      --timeout) timeout="${2:-}"; shift 2 || die 'usage: glimpse wait <selector> | --text <str> [--timeout N]';;
      *) pos+=("$1"); shift;;
    esac
  done
  local selector="${pos[0]:-}"
  [ -n "$selector" ] || [ -n "$text" ] || die 'usage: glimpse wait <selector> | --text <str> [--timeout N]'
  case "$timeout" in *[!0-9]*|"") die "--timeout must be a number of seconds";; esac
  cmd_chrome >/dev/null
  local f; f="$(_lib_file glimpse-interact.mjs)" || die "glimpse-interact.mjs not found — reinstall glimpse"
  ACTION=wait SELECTOR="$selector" TEXT="$text" TIMEOUT_MS="$((timeout*1000))" run_cdp "$(cat "$f")"
}

# glimpse poll — ONE blocking call the agent parks on. It waits until there is
# undelivered human feedback (a pending highlight/question), prints it as compact
# structured records (or --json), then returns. Built on the same files-on-disk,
# pull-only drain machinery as the bridge: each tick it drains the canvas outbox
# into the durable thread store (idempotent, so it coexists with a bridge/daemon)
# and blocks on the pending queue — so queued feedback survives if the agent wasn't
# polling yet, and the next poll delivers the next item (nothing dropped). Degrades
# to disk-only when Chrome is down. Exit: 0 delivered · 3 timed out with nothing.
cmd_poll(){
  local as_json=0 timeout=300 interval=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)     as_json=1; shift;;
      --timeout)  timeout="${2:-}";  shift 2 || die "usage: glimpse poll [--json] [--timeout N] [--interval S]";;
      --interval) interval="${2:-}"; shift 2 || die "usage: glimpse poll [--json] [--timeout N] [--interval S]";;
      *) die "usage: glimpse poll [--json] [--timeout N] [--interval S]";;
    esac
  done
  case "$timeout" in *[!0-9]*|"") die "--timeout must be a whole number of seconds (0 = wait indefinitely)";; esac
  require_node
  local interval_ms=500
  if [ -n "$interval" ]; then
    interval_ms="$(node -e 'const v=parseFloat(process.argv[1]); if(!isFinite(v)){process.exit(1)} process.stdout.write(String(Math.max(100,Math.trunc(v*1000))))' "$interval" 2>/dev/null)" \
      || die "--interval must be seconds, e.g. 0.5"
  fi
  seed_root
  # One poll per canvas cursor: a second concurrent poll would race the .poll.state
  # delivered set and could double-deliver. Stale-pid detection mirrors cmd_bridge.
  local lock="$GLIMPSE_DIR/.poll.lock" opid
  if [ -f "$lock" ]; then
    opid="$(cat "$lock" 2>/dev/null || true)"
    if [ -n "$opid" ] && kill -0 "$opid" 2>/dev/null; then die "poll already running (pid $opid) — one blocking poll at a time"; fi
  fi
  echo $$ > "$lock"; _POLL_LOCK="$lock"
  trap _poll_cleanup EXIT INT TERM
  # Splice the CDP helper ahead of the poll loop (cdpConnect in scope), exactly as
  # cmd_bridge composes cdp + bridge.
  local cdp poll
  cdp="$(_lib_file glimpse-cdp.mjs)"   || die "glimpse-cdp.mjs not found — reinstall glimpse"
  poll="$(_lib_file glimpse-poll.mjs)" || die "glimpse-poll.mjs not found — reinstall glimpse"
  GLIMPSE_BIN="$SELF_DIR/$(basename "$SOURCE")" POLL_JSON="$as_json" \
    POLL_TIMEOUT_MS="$((timeout*1000))" POLL_INTERVAL_MS="$interval_ms" \
    node --input-type=module -e "$(cat "$cdp")"$'\n'"$(cat "$poll")" &
  _POLL_NODE_PID=$!
  local rc=0; wait "$_POLL_NODE_PID" || rc=$?    # capture child rc without tripping set -e (so cleanup runs)
  exit "$rc"
}

# Accessibility-tree text snapshot of the current (or given) page — the readable,
# token-efficient sibling of `shot` (pixels) and `read` (innerText). Reuses the
# same CDP channel (run_cdp) and is read-only: it navigates only when handed a
# target, never mutates the page.
#
# `#slug` resolves to the artifact's own served document (artifacts/<slug>.html),
# NOT the canvas hash route: the canvas renders artifacts inside a sandboxed,
# opaque-origin iframe whose a11y tree CDP can't reach from the shell, so
# snapshotting the file directly yields the artifact's full, clean tree instead of
# a bare `Iframe` leaf. Anything else is treated as a URL. With no target the
# current page is captured in place.
cmd_snapshot(){
  local target="${1:-}" url=""
  if [ -n "$target" ]; then
    if [[ "$target" == \#* ]]; then
      local s="${target#\#}"; _validate_slug "$s"
      url="http://127.0.0.1:${PORT}/artifacts/${s}.html"
      cmd_serve >/dev/null            # the served file needs the static server up
    else
      url="$target"
    fi
  fi
  cmd_chrome >/dev/null
  local snap; snap="$(_lib_file glimpse-snapshot.mjs)" || die "glimpse-snapshot.mjs not found — reinstall glimpse"
  URL="$url" run_cdp "$(cat "$snap")"
}

cmd_bridge(){
  local wait=0
  case "${1:-}" in --wait) wait=1;; "") ;; *) die "usage: glimpse bridge [--wait]";; esac
  require_node
  seed_root
  # One bridge per canvas — a second reader would double-deliver every question.
  local lock="$GLIMPSE_DIR/.bridge.lock" opid
  if [ -f "$lock" ]; then
    opid="$(cat "$lock" 2>/dev/null || true)"
    if [ -n "$opid" ] && kill -0 "$opid" 2>/dev/null; then die "bridge already running (pid $opid)"; fi
  fi
  echo $$ > "$lock"
  # Kill the node child on exit/signal too — otherwise killing the launcher
  # orphans a live bridge while the lock is cleaned (→ silent double readers).
  _BRIDGE_LOCK="$lock"
  trap _bridge_cleanup EXIT INT TERM
  echo "glimpse: bridge listening for highlight questions (canvas 127.0.0.1:$PORT) — Ctrl-C to stop" >&2
  # Splice the CDP helper ahead of the bridge loop (cdpConnect is in scope),
  # exactly as the former CDP_HELPER/BRIDGE_JS heredocs were composed.
  local cdp bridge
  cdp="$(_lib_file glimpse-cdp.mjs)"     || die "glimpse-cdp.mjs not found — reinstall glimpse"
  bridge="$(_lib_file glimpse-bridge.mjs)" || die "glimpse-bridge.mjs not found — reinstall glimpse"
  GLIMPSE_BIN="$SELF_DIR/$(basename "$SOURCE")" WAIT="$wait" \
    node --input-type=module -e "$(cat "$cdp")"$'\n'"$(cat "$bridge")" &
  _BRIDGE_NODE_PID=$!
  local rc=0; wait "$_BRIDGE_NODE_PID" || rc=$?    # capture child rc without tripping set -e (so cleanup runs)
  exit "$rc"
}

# glimpse daemon — the bridge PLUS auto-answering each question by calling the
# local Anthropic-compatible proxy. This is what makes the canvas "always-on"
# without a human in the loop. Q&A only; never acts on the question text.
cmd_daemon(){
  local key="${GLIMPSE_API_KEY:-${POE_API_KEY:-${ANTHROPIC_API_KEY:-}}}"
  [ -n "$key" ] || die "daemon needs an API key — set GLIMPSE_API_KEY (or POE_API_KEY / ANTHROPIC_API_KEY)"
  local base="${GLIMPSE_PROXY_URL:-}"
  if [ -z "$base" ] && [ -n "${ANTHROPIC_BASE_URL:-}" ]; then base="${ANTHROPIC_BASE_URL%/}/v1/messages"; fi
  base="${base:-http://127.0.0.1:8787/v1/messages}"
  export GLIMPSE_ANSWER=1 GLIMPSE_API_KEY="$key" GLIMPSE_PROXY_URL="$base" GLIMPSE_MODEL="${GLIMPSE_MODEL:-claude-haiku-4-5}"
  echo "glimpse: daemon auto-answering via $base (model $GLIMPSE_MODEL)" >&2
  # Warn (don't die — it may come up later) if the proxy isn't reachable; otherwise
  # every question silently fails with proxy_unavailable and nothing explains why.
  local rc=0; curl -s -o /dev/null -m 3 "$base" 2>/dev/null || rc=$?
  if [ "$rc" = 7 ] || [ "$rc" = 28 ]; then
    echo "glimpse: warning — proxy $base is unreachable; answers will fail until it's up (set GLIMPSE_PROXY_URL or ANTHROPIC_BASE_URL)" >&2
  fi
  cmd_bridge "$@"
}

# glimpse menubar — launch the macOS menu-bar app (toggle/keep the daemon online).
cmd_menubar(){
  local app="$SELF_DIR/../app/glimpse_menubar.py"
  [ -f "$app" ] || app="$GLIMPSE_DIR/glimpse_menubar.py"
  [ -f "$app" ] || die "menu-bar app not found (app/glimpse_menubar.py) — reinstall glimpse"
  local self; self="$SELF_DIR/$(basename "$SOURCE")"; export GLIMPSE_BIN_PATH="$self"
  if python3 -c "import rumps" >/dev/null 2>&1; then exec python3 "$app"; fi
  # Resolve uv even under a minimal PATH. launchd runs this via `bash -lc`, which
  # reads bash login files — not the interactive zsh PATH — so `command -v uv`
  # misses ~/.local/bin and the menu-bar silently never starts. Fall back to uv's
  # usual install locations before giving up.
  local uv; uv="$(command -v uv 2>/dev/null || true)"
  local c; for c in "$HOME/.local/bin/uv" "/opt/homebrew/bin/uv" "/usr/local/bin/uv"; do
    [ -n "$uv" ] && break; [ -x "$c" ] && uv="$c"
  done
  if [ -n "$uv" ]; then echo "glimpse: launching menu-bar via uv (fetching rumps the first time)…" >&2; exec "$uv" run --with rumps python3 "$app"
  else die "the menu-bar needs the 'rumps' package — install uv (https://docs.astral.sh/uv/) then it's automatic, or:  uv pip install rumps"; fi
}

# Faithfully reproduce how the always-on launchd daemon resolves a runtime binary
# and echo the path it would use (empty if it wouldn't find one). The daemon runs
# `/bin/bash -lc 'source secrets; exec glimpse …'` under launchd's minimal PATH —
# which misses the fnm/nvm setup that only zsh sources — so we re-run that same
# login-shell + secrets sourcing here. For node we then apply glimpse's own
# fallback probe INSIDE that same sourced subshell, so a GLIMPSE_NODE (or PATH)
# pinned only in secrets.env is honored exactly as _ensure_node would — otherwise
# doctor reports a false "launchd node" failure whose printed fix wouldn't clear
# it. The shared _node_candidates list is fed in via env (never re-copied) so this
# check can't drift from _ensure_node, and its GLIMPSE_NODE entry is re-evaluated
# inside the subshell from the sourced secrets rather than the doctor's own env.
# Always returns 0 so a `x=$(_launchd_resolve …)` assignment is safe under set -e.
_launchd_resolve(){
  local cmd="$1" secrets="$HOME/.config/secrets.env" found
  found="$(env -i HOME="$HOME" PATH="/usr/bin:/bin:/usr/sbin:/sbin" \
    SECRETS="$secrets" CMD="$cmd" CANDS="$(_node_candidates)" \
    /bin/bash -lc '
      source "$SECRETS" 2>/dev/null || true
      p="$(command -v "$CMD" 2>/dev/null || true)"
      [ -n "$p" ] && { printf "%s" "$p"; exit 0; }
      [ "$CMD" = node ] || exit 0
      while IFS= read -r c; do
        [ -n "$c" ] && [ -x "$c" ] && { printf "%s (glimpse fallback)" "$c"; exit 0; }
      done <<CANDLIST
${GLIMPSE_NODE:-}
$CANDS
CANDLIST
    ' 2>/dev/null || true)"
  echo "$found"; return 0
}

cmd_doctor(){
  local fail=0
  # One line per check. ✓ good · ✗ broken (fails the run) · ⚠ optional/degraded
  # · – informational state. Every ✗/⚠ is followed by a copy-pasteable fix.
  _dok(){   printf "  ✓ %-15s %s\n" "$1" "$2"; }
  _dbad(){  printf "  ✗ %-15s %s\n" "$1" "$2"; fail=1; }
  _dwarn(){ printf "  ⚠ %-15s %s\n" "$1" "$2"; }
  _dnote(){ printf "  – %-15s %s\n" "$1" "$2"; }
  _dfix(){  printf "      → %s\n" "$1"; }

  echo "glimpse doctor  (dir: $GLIMPSE_DIR  canvas :$PORT  cdp :$CDP_PORT)"

  # --- required runtime ------------------------------------------------------
  if [ -n "${BASH_VERSION:-}" ]; then _dok bash "$BASH_VERSION"
  else _dbad bash "not running under bash"; _dfix "run glimpse with bash (its shebang is /usr/bin/env bash)"; fi

  if have node && node -e 'process.exit(parseInt(process.version.slice(1),10)>=22?0:1)' 2>/dev/null; then
    _dok node "$(node --version)"
  elif have node; then _dbad node "$(node --version) too old — CDP needs node 22+ (global WebSocket)"
       _dfix "$([ "$(uname -s)" = Darwin ] && echo 'brew install node   # or: fnm install 22 && fnm default 22' || echo 'install Node 22+ from https://nodejs.org')"
  else _dbad node "MISSING — needed to drive Chrome over CDP (v22+)"
       _dfix "$([ "$(uname -s)" = Darwin ] && echo 'brew install node   # or: fnm install 22 && fnm default 22' || echo 'install Node 22+ from https://nodejs.org')"; fi

  local chrome; if chrome="$(detect_chrome)"; then _dok chrome "$chrome"
  else _dbad chrome "not found"
       _dfix "$([ "$(uname -s)" = Darwin ] && echo 'brew install --cask google-chrome   # or set GLIMPSE_CHROME=/path/to/chrome' || echo 'install Chrome/Chromium, or set GLIMPSE_CHROME=/path/to/chrome')"; fi

  if have curl; then _dok curl "ok"
  else _dbad curl "MISSING — needed for readiness checks"; _dfix "install curl with your package manager"; fi

  # --- live services (state, not install errors — 'down' is normal) ----------
  if curl -fsS "http://127.0.0.1:${PORT}/feed.json" >/dev/null 2>&1; then _dok server "up on :$PORT"
  else _dnote server "down on :$PORT — start with: glimpse serve  (or: glimpse open)"; fi

  if curl -fsS "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1; then _dok "cdp port" "debuggable Chrome on :$CDP_PORT"
  else _dnote "cdp port" "no debuggable Chrome on :$CDP_PORT — start with: glimpse chrome  (or: glimpse open)"; fi

  # --- always-on daemon (macOS launchd) --------------------------------------
  local plist="$HOME/Library/LaunchAgents/com.glimpse.menubar.plist"
  if [ "$(uname -s)" = Darwin ] && [ -f "$plist" ]; then
    if launchctl print "gui/$(id -u)/com.glimpse.menubar" >/dev/null 2>&1; then _dok "launchd job" "loaded (com.glimpse.menubar)"
    else _dbad "launchd job" "plist present but not loaded"
         _dfix "launchctl bootstrap gui/$(id -u) \"$plist\"   # or toggle 'Start at login' in the menu bar"; fi
    # The classic silent failure: launchd's login shell can't find node/python3.
    local dnode; dnode="$(_launchd_resolve node)"
    if [ -n "$dnode" ]; then _dok "launchd node" "$dnode"
    else _dbad "launchd node" "the daemon's login shell can't find node → CDP dies silently"
         _dfix "echo 'export GLIMPSE_NODE=\"'\"\$(command -v node)\"'\"' >> ~/.config/secrets.env   then re-toggle 'Start at login'"; fi
    # python3 is optional (only the macOS menu-bar app uses it, via rumps); a
    # missing one degrades that GUI but never fails core glimpse (Node + Chrome).
    local dpy; dpy="$(_launchd_resolve python3)"
    if [ -n "$dpy" ]; then _dok "launchd python3" "$dpy (menu-bar app)"
    else _dwarn "launchd python3" "the daemon's login shell can't find python3 — the menu-bar app (rumps) won't start"
         _dfix "echo 'export PATH=\"'\"\$(dirname \"\$(command -v python3)\")\"':\$PATH\"' >> ~/.config/secrets.env   then re-toggle 'Start at login'"; fi
  elif [ "$(uname -s)" = Darwin ]; then
    _dnote launchd "always-on daemon not configured — enable via the menu-bar 'Start at login' (glimpse menubar)"
  fi

  # --- optional features / assets --------------------------------------------
  if [ ! -f "$GLIMPSE_DIR/glimpse-annotate.js" ]; then _dwarn annotate "asset missing"; _dfix "glimpse serve   # re-seeds canvas assets"
  elif [ "$ANNOTATE" = "0" ]; then _dnote annotate "installed (disabled via GLIMPSE_ANNOTATE=0)"
  else _dok annotate "installed"; fi

  if [ -f "$GLIMPSE_DIR/glimpse-explain.mjs" ] || [ -f "$SELF_DIR/../lib/glimpse-explain.mjs" ]; then _dok explain "engine installed"
  else _dwarn explain "engine missing"; _dfix "re-run install.sh to restore lib/glimpse-explain.mjs"; fi

  if [ -f "$GLIMPSE_DIR/glimpse-ask.mjs" ] || [ -f "$SELF_DIR/../lib/glimpse-ask.mjs" ]; then _dok "ask form" "engine installed"
  else _dwarn "ask form" "engine missing"; _dfix "re-run install.sh to restore lib/glimpse-ask.mjs  (plain ask still works)"; fi

  local bp; bp="$(cat "$GLIMPSE_DIR/.bridge.lock" 2>/dev/null || true)"
  if [ -n "$bp" ] && kill -0 "$bp" 2>/dev/null; then _dok bridge "running (pid $bp)"
  else _dnote bridge "not running — start with: glimpse bridge  (or: glimpse daemon)"; fi

  local pbase="${GLIMPSE_PROXY_URL:-${ANTHROPIC_BASE_URL:+${ANTHROPIC_BASE_URL%/}/v1/messages}}"; pbase="${pbase:-http://127.0.0.1:8787/v1/messages}"
  local prc=0; curl -s -o /dev/null -m 3 "$pbase" 2>/dev/null || prc=$?
  if [ "$prc" = 7 ] || [ "$prc" = 28 ]; then _dnote proxy "unreachable: $pbase (daemon answers will fail until it's up)"
  else _dok proxy "reachable: $pbase"; fi

  if [ -n "${GLIMPSE_API_KEY:-${POE_API_KEY:-${ANTHROPIC_API_KEY:-}}}" ]; then _dok "api key" "set"
  else _dnote "api key" "unset — the auto-answer daemon needs GLIMPSE_API_KEY (or POE_API_KEY / ANTHROPIC_API_KEY)"; fi

  echo
  if [ "$fail" = 0 ]; then echo "✓ all required checks passed."
  else echo "✗ some required checks failed (see ✗ lines above) — fix them, then re-run: glimpse doctor" >&2; fi
  return $fail
}

cmd_list(){
  local as_json=0
  case "${1:-}" in --json) as_json=1;; "") ;; *) die "usage: glimpse list [--json]";; esac
  require_node
  local f; f="$(_lib_file glimpse-feed.mjs)" || die "glimpse-feed.mjs not found — reinstall glimpse"
  GLIMPSE_DIR="$GLIMPSE_DIR" LIST_JSON="$as_json" node "$f" list
}

cmd_rm(){
  [ $# -ge 1 ] || die "usage: glimpse rm <slug>..."
  local s; for s in "$@"; do _validate_slug "$s"; done
  local removed; removed="$(ACTION=remove SLUGS="$*" _feed_op)"
  local r n=0; for r in $removed; do rm -f "$ARTIFACTS/$r.html"; n=$((n+1)); done
  # Remove threads for every requested slug — including ones already absent from
  # the feed, so a `rm <slug>` never leaves an orphan thread behind.
  for r in "$@"; do rm -f "$THREADS/$r.json" "$THREADS/$r.json.lock"; done
  echo "removed $n artifact(s)${removed:+: $(echo $removed | tr '\n' ' ')}"
}

cmd_clear(){
  local mode n
  case "${1:-}" in
    --all)  mode=removeall;;
    --keep) n="${2:-}"; mode=keep; case "$n" in *[!0-9]*|"") die "--keep needs a number, e.g. glimpse clear --keep 10";; esac;;
    *) die "usage: glimpse clear --all | --keep N   (pinned artifacts are always kept)";;
  esac
  local removed; removed="$(ACTION=$mode KEEP="${n:-0}" _feed_op)"
  local r cnt=0; for r in $removed; do rm -f "$ARTIFACTS/$r.html" "$THREADS/$r.json" "$THREADS/$r.json.lock"; cnt=$((cnt+1)); done
  echo "removed $cnt artifact(s)$([ "$mode" = keep ] && echo " (kept newest $n + pinned)")"
}

cmd_pin(){   local s="${1:?usage: glimpse pin <slug>}";   _validate_slug "$s"; ACTION=pin   SLUG="$s" _feed_op >/dev/null; echo "pinned $s";   }
cmd_unpin(){ local s="${1:?usage: glimpse unpin <slug>}"; _validate_slug "$s"; ACTION=unpin SLUG="$s" _feed_op >/dev/null; echo "unpinned $s"; }

# --- highlight-chat: per-document threads -----------------------------------
# The user highlights a passage in an artifact and asks; the bridge records the
# question as a pending user turn; the agent answers with `reply`.
cmd_reply(){
  local to=""; local -a pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --to) to="${2:-}"; shift 2 || die 'usage: glimpse reply <slug> "answer" --to <turnId>';;
      --)   shift; while [ $# -gt 0 ]; do pos+=("$1"); shift; done;;   # everything after -- is positional (answer may start with "--")
      *)    pos+=("$1"); shift;;
    esac
  done
  local slug="${pos[0]:-}" text="${pos[1]:-}"
  [ -n "$slug" ] && [ -n "$text" ] && [ -n "$to" ] || die 'usage: glimpse reply <slug> "answer" --to <turnId>'
  _validate_slug "$slug"
  [ -f "$THREADS/$slug.json" ] || die "no thread '$slug' — the user hasn't asked anything here yet. try: glimpse threads"
  local id
  id="$(ACTION=add_agent SLUG="$slug" TEXT="$text" TO="$to" TS="$(date +%s)" _thread_op)"
  echo "replied → $slug turn $id (in answer to $to)"
}

cmd_thread(){
  local slug="${1:-}"
  [ -n "$slug" ] || die "usage: glimpse thread <slug> [--json|--clear]"
  _validate_slug "$slug"
  case "${2:-}" in
    --json)  ACTION=print_json SLUG="$slug" _thread_op;;
    --clear) ACTION=clear      SLUG="$slug" _thread_op >/dev/null && { rm -f "$THREADS/$slug.json.lock"; echo "cleared thread $slug"; };;
    "")      ACTION=print      SLUG="$slug" _thread_op;;
    *) die "usage: glimpse thread <slug> [--json|--clear]";;
  esac
}

cmd_threads(){
  require_node
  local f; f="$(_lib_file glimpse-threads.mjs)" || die "glimpse-threads.mjs not found — reinstall glimpse"
  GLIMPSE_DIR="$GLIMPSE_DIR" node "$f" list
}

# Internal plumbing for `glimpse bridge` (not user-facing). The bridge runs in
# Node (CDP); it shells back to these so all thread writes share one flocked
# Node writer instead of a second, drifting implementation.
cmd__thread_add_user(){
  [ -n "${SLUG:-}" ] || die "SLUG required"
  _validate_slug "$SLUG"                       # slug originates in the page → re-validate
  ACTION=add_user _thread_op
}
cmd__pending(){
  require_node
  local f; f="$(_lib_file glimpse-threads.mjs)" || die "glimpse-threads.mjs not found — reinstall glimpse"
  GLIMPSE_DIR="$GLIMPSE_DIR" node "$f" pending
}

usage(){ awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$SOURCE"; }

# Dispatch only when executed directly. Sourcing the script (e.g. from the disk-level
# unit tests) then loads the function definitions without running a command, so the
# pure-disk helpers (_maybe_welcome, _publish_demo_set, …) can be exercised without a
# browser. No behavior change when run as a CLI.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
case "${1:-help}" in
  open)    shift; cmd_open "$@";;
  demo)    shift; cmd_demo "$@";;
  publish) shift; cmd_publish "$@";;
  explain) shift; cmd_explain "$@";;
  ask)     shift; cmd_ask "$@";;
  export)  shift; cmd_export "$@";;
  share)   shift; cmd_share "$@";;
  shares)  shift; cmd_shares "$@";;
  list|ls) shift; cmd_list "$@";;
  rm)      shift; cmd_rm "$@";;
  clear)   shift; cmd_clear "$@";;
  pin)     shift; cmd_pin "$@";;
  unpin)   shift; cmd_unpin "$@";;
  reply)   shift; cmd_reply "$@";;
  thread)  shift; cmd_thread "$@";;
  threads) shift; cmd_threads "$@";;
  poll)    shift; cmd_poll "$@";;
  bridge)  shift; cmd_bridge "$@";;
  daemon)  shift; cmd_daemon "$@";;
  menubar) shift; cmd_menubar "$@";;
  __thread-add-user) shift; cmd__thread_add_user "$@";;
  __pending)         shift; cmd__pending "$@";;
  serve)   shift; cmd_serve "$@";;
  stop)    shift; cmd_stop "$@";;
  chrome)  shift; cmd_chrome "$@";;
  read)    shift; cmd_read "$@";;
  shot)    shift; cmd_shot "$@";;
  snapshot) shift; cmd_snapshot "$@";;
  click)   shift; cmd_click "$@";;
  scroll)  shift; cmd_scroll "$@";;
  wait)    shift; cmd_wait "$@";;
  audit)   shift; cmd_audit "$@";;
  doctor)  shift; cmd_doctor "$@";;
  help|-h|--help) usage;;
  *) die "unknown command '${1}'. Try: glimpse help";;
esac
fi
