# Runtime canvas data (lives in ~/.glimpse by default, but ignore if pointed here)
.glimpse/
artifacts/
feed.json
.server.log
*.png
# brand assets (menu-bar icon) — tracked despite *.png
!assets/menubar-on.png
!assets/menubar-off.png
!assets/glimpse-hero-light.png
!assets/glimpse-hero-dark.png
# playbook example screenshots — tracked despite *.png (reference for reviewers)
!examples/screenshots/
!examples/screenshots/*.png
# GitHub Pages showcase site assets — tracked despite *.png
!docs/assets/
!docs/assets/*.png
!docs/assets/shots/
!docs/assets/shots/*.png
.DS_Store
__pycache__/
*.pyc

# Secrets / credentials — never commit these
.env
.env.*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
secrets.env
secrets.yaml
secrets.yml
secrets.json
credentials.json
*.local
